{
  "app": {
    "name": "Esoft",
    "openBrowser": true,
    "openAddress": "local"
  },
  "network": {
    "host": "auto",
    "backendPort": 3000,
    "frontendPort": 5173
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "esoft",
    "user": "esoft",
    "password": "replace-with-db-password",
    "schema": "public"
  },
  "auth": {
    "secret": "replace-with-generated-secret"
  },
  "storage": {
    "provider": "minio",
    "endpoint": "http://127.0.0.1:9000",
    "console": "http://127.0.0.1:9001",
    "bucket": "esoft",
    "accessKey": "esoft",
    "secretKey": "replace-with-minio-password",
    "dataPath": "C:\\EsoftData\\minio",
    "executablePath": "C:\\Esoft\\tools\\minio.exe",
    "forcePathStyle": true,
    "region": "us-east-1"
  },
  "logs": {
    "directory": "logs"
  }
}
