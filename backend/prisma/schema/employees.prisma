model Employee {
  id                   Int           @id @default(autoincrement())
  lastName             String        @map("last_name") @db.VarChar(64)
  firstName            String        @map("first_name") @db.VarChar(64)
  middleName           String?       @map("middle_name") @db.VarChar(64)
  position             String        @db.VarChar(64)
  employeeUser         EmployeeUser?
  responsibleEquipment Equipment[]   @relation("EquipmentResponsibleEmployee")

  @@index([lastName, firstName, middleName], map: "idx_employees_full_name")
  @@map("employees")
}

model EmployeeUser {
  employeeId Int      @unique(map: "uq_employee_users_employee") @map("employee_id")
  userId     String   @unique(map: "uq_employee_users_user") @map("user_id")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([employeeId, userId])
  @@map("employee_users")
}
