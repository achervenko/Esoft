model Manufacturer {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(128)
  equipment Equipment[]
  models    EquipmentModel[]

  @@map("manufacturers")
}

model EquipmentModel {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(128)
  manufacturerId Int          @map("manufacturer_id")
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  equipment      Equipment[]

  @@unique([manufacturerId, name], map: "uq_equipment_models_manufacturer_name")
  @@index([manufacturerId], map: "idx_equipment_models_manufacturer_id")
  @@map("equipment_models")
}

model Country {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(128)
  iso       String      @unique @db.Char(2)
  equipment Equipment[]

  @@map("countries")
}

model Workshop {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(128)
  sections Section[]

  @@map("workshops")
}

model Section {
  id         Int         @id @default(autoincrement())
  workshopId Int         @map("workshop_id")
  workshop   Workshop    @relation(fields: [workshopId], references: [id], onDelete: Restrict)
  name       String      @db.VarChar(128)
  equipment  Equipment[]

  @@unique([workshopId, name], map: "uq_sections_workshop_name")
  @@index([workshopId], map: "idx_sections_workshop_id")
  @@map("sections")
}
