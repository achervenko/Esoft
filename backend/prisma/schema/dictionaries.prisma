model Manufacturer {
  id        Int              @id @default(autoincrement())
  name      String           @unique @db.VarChar(128)
  isActive  Boolean          @default(true) @map("is_active")
  equipment Equipment[]
  models    EquipmentModel[]

  @@map("manufacturers")
}

model EquipmentModel {
  id                  Int                           @id @default(autoincrement())
  name                String                        @db.VarChar(128)
  isActive            Boolean                       @default(true) @map("is_active")
  manufacturerId      Int                           @map("manufacturer_id")
  manufacturer        Manufacturer                  @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  equipment           Equipment[]
  maintenanceSettings EquipmentMaintenanceSetting[]

  @@unique([manufacturerId, name], map: "uq_equipment_models_manufacturer_name")
  @@index([manufacturerId], map: "idx_equipment_models_manufacturer_id")
  @@map("equipment_models")
}

model EquipmentEventType {
  id                  Int                           @id @default(autoincrement())
  name                String                        @unique(map: "uq_equipment_event_types_name") @db.VarChar(64)
  code                String                        @unique(map: "uq_equipment_event_types_code") @db.VarChar(32)
  isActive            Boolean                       @default(true) @map("is_active")
  events              EquipmentEvent[]
  maintenanceSettings EquipmentMaintenanceSetting[]

  @@map("equipment_event_types")
}

enum EquipmentMaintenanceExecutionType {
  INTERNAL
  EXTERNAL

  @@map("equipment_maintenance_execution_type")
}

model EquipmentMaintenanceSetting {
  id                         Int                               @id @default(autoincrement())
  equipmentModelId           Int                               @map("equipment_model_id")
  maintenanceTypeId          Int                               @map("maintenance_type_id")
  defaultChecklistTemplateId Int?                              @map("default_checklist_template_id")
  executionType              EquipmentMaintenanceExecutionType @map("execution_type")
  periodicityYears           Int?                              @map("periodicity_years")
  periodicityMonths          Int?                              @map("periodicity_months")
  periodicityWeeks           Int?                              @map("periodicity_weeks")
  periodicityDays            Int?                              @map("periodicity_days")
  createdAt                  DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                          @updatedAt @map("updated_at") @db.Timestamptz(6)

  equipmentModel           EquipmentModel     @relation(fields: [equipmentModelId], references: [id], onDelete: Restrict)
  maintenanceType          EquipmentEventType @relation(fields: [maintenanceTypeId], references: [id], onDelete: Restrict)
  defaultChecklistTemplate ChecklistTemplate? @relation("ChecklistTemplateDefaultForMaintenanceSettings", fields: [defaultChecklistTemplateId], references: [id], onDelete: Restrict, map: "fk_equipment_maintenance_settings_default_template")
  events                   EquipmentEvent[]

  @@unique([equipmentModelId, maintenanceTypeId], map: "uq_equipment_maintenance_settings_model_type")
  @@index([maintenanceTypeId], map: "idx_equipment_maintenance_settings_type_id")
  @@index([defaultChecklistTemplateId], map: "idx_equipment_maintenance_settings_default_template_id")
  @@map("equipment_maintenance_settings")
}

model Country {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(128)
  iso       String      @unique @db.Char(2)
  equipment Equipment[]

  @@map("countries")
}

model Workshop {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(128)
  sections Section[]

  @@map("workshops")
}

model Section {
  id         Int         @id @default(autoincrement())
  workshopId Int         @map("workshop_id")
  workshop   Workshop    @relation(fields: [workshopId], references: [id], onDelete: Restrict)
  name       String      @db.VarChar(128)
  equipment  Equipment[]

  @@unique([workshopId, name], map: "uq_sections_workshop_name")
  @@index([workshopId], map: "idx_sections_workshop_id")
  @@map("sections")
}
