enum StorageOwnerModule {
  EQUIPMENT @map("equipment")

  @@map("storage_owner_module")
}

model StorageFile {
  id               Int                @id @default(autoincrement())
  bucket           String             @db.VarChar(63)
  objectKey        String             @unique @map("object_key") @db.VarChar(512)
  originalName     String             @map("original_name") @db.VarChar(255)
  mimeType         String             @map("mime_type") @db.VarChar(128)
  sizeBytes        BigInt             @map("size_bytes")
  ownerModule      StorageOwnerModule @map("owner_module")
  ownerEntityType  String             @map("owner_entity_type") @db.VarChar(64)
  ownerEntityId    Int                @map("owner_entity_id")
  uploadedByUserId String?            @map("uploaded_by_user_id")
  uploadedByUser   User?              @relation("UploadedStorageFiles", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(dbgenerated("timezone('Europe/Moscow'::text, now())")) @map("created_at") @db.Timestamp(6)
  deletedAt        DateTime?          @map("deleted_at") @db.Timestamp(6)

  @@index([bucket], map: "idx_storage_files_bucket")
  @@index([createdAt(sort: Desc)], map: "idx_storage_files_created_at")
  @@index([uploadedByUserId], map: "idx_storage_files_uploaded_by_user_id")
  @@index([deletedAt], map: "idx_storage_files_deleted_at")
  @@index([ownerModule, ownerEntityType, ownerEntityId, deletedAt], map: "idx_storage_files_owner")
  @@index([ownerEntityId], map: "idx_storage_files_owner_entity_id")
  @@map("storage_files")
}
