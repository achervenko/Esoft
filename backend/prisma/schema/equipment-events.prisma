enum EquipmentEventSource {
  MANUAL
  PLANNED

  @@map("equipment_event_source")
}

enum EquipmentEventStatus {
  DRAFT
  CREATED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("equipment_event_status")
}

model EquipmentEvent {
  id                   Int                               @id @default(autoincrement())
  equipmentId          Int                               @map("equipment_id")
  eventTypeId          Int                               @map("event_type_id")
  maintenanceSettingId Int?                              @map("maintenance_setting_id")
  executionType        EquipmentMaintenanceExecutionType @map("execution_type")
  source               EquipmentEventSource
  status               EquipmentEventStatus              @default(CREATED)
  originalPlannedDate  DateTime?                         @map("original_planned_date") @db.Date
  plannedDate          DateTime?                         @map("planned_date") @db.Date
  factDate             DateTime?                         @map("fact_date") @db.Date
  note                 String?
  createdByEmployeeId  Int                               @map("created_by_employee_id")
  createdAt            DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  version              Int                               @default(1)

  equipment          Equipment                    @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  eventType          EquipmentEventType           @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  maintenanceSetting EquipmentMaintenanceSetting? @relation(fields: [maintenanceSettingId], references: [id], onDelete: SetNull)
  createdByEmployee  Employee                     @relation("EquipmentEventCreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: Restrict)
  responsibles       EquipmentEventResponsible[]
  checklists         Checklist[]

  @@index([equipmentId], map: "idx_equipment_events_equipment_id")
  @@index([eventTypeId], map: "idx_equipment_events_event_type_id")
  @@index([status], map: "idx_equipment_events_status")
  @@index([plannedDate], map: "idx_equipment_events_planned_date")
  @@index([factDate], map: "idx_equipment_events_fact_date")
  @@index([maintenanceSettingId], map: "idx_equipment_events_maintenance_setting_id")
  @@map("equipment_events")
}

model EquipmentEventResponsible {
  equipmentEventId Int            @map("equipment_event_id")
  userId           String         @map("user_id")
  equipmentEvent   EquipmentEvent @relation(fields: [equipmentEventId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@id([equipmentEventId, userId], map: "pk_equipment_event_responsibles")
  @@index([userId], map: "idx_event_responsibles_user_id")
  @@map("equipment_event_responsibles")
}
