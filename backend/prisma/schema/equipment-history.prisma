enum EquipmentChangeType {
  CREATE
  UPDATE
  STATUS_CHANGE
  RESPONSIBLE_CHANGE
  SECTION_CHANGE
  WRITE_OFF

  @@map("equipment_change_type")
}

model EquipmentHistory {
  id          Int                 @id @default(autoincrement())
  equipmentId Int                 @map("equipment_id")
  equipment   Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  changedAt   DateTime            @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedBy   String?             @map("changed_by")
  changedUser User?               @relation(fields: [changedBy], references: [id], onDelete: SetNull)
  changeType  EquipmentChangeType @map("change_type")
  fieldName   String?             @map("field_name") @db.VarChar(64)
  oldValue    String?             @map("old_value")
  newValue    String?             @map("new_value")
  comment     String?

  @@index([equipmentId], map: "idx_equipment_history_equipment_id")
  @@index([changedAt(sort: Desc)], map: "idx_equipment_history_changed_at")
  @@index([changedBy], map: "idx_equipment_history_changed_by")
  @@index([changeType], map: "idx_equipment_history_change_type")
  @@map("equipment_history")
}
