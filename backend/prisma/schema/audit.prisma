enum AuditAction {
  CREATE
  UPDATE
  ARCHIVE
  DELETE
  STATUS_CHANGE
  FILE_UPLOAD
  FILE_DELETE
  LOGIN
  LOGOUT
  USER_BLOCK
  USER_PHOTO_DELETE
  USER_PHOTO_UPLOAD
  ROLE_CHANGE

  @@map("audit_action")
}

enum AuditModule {
  EQUIPMENT @map("equipment")
  USERS     @map("users")

  @@map("audit_module")
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  timeZone   String      @default("Europe/Moscow (UTC+03:00)") @map("time_zone") @db.VarChar(32)
  userId     String?     @map("user_id")
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull, map: "fk_audit_log_user")
  module     AuditModule @default(EQUIPMENT)
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(64)
  entityId   Int?        @map("entity_id")
  fieldName  String?     @map("field_name") @db.VarChar(128)
  oldValue   String?     @map("old_value") @db.Text
  newValue   String?     @map("new_value") @db.Text

  @@index([createdAt(sort: Desc)], map: "idx_audit_log_created_at")
  @@index([userId], map: "idx_audit_log_user_id")
  @@index([module], map: "idx_audit_log_module")
  @@index([entityType, entityId], map: "idx_audit_log_entity")
  @@index([entityId], map: "idx_audit_log_entity_id")
  @@index([fieldName], map: "idx_audit_log_field_name")
  @@index([action], map: "idx_audit_log_action")
  @@map("audit_log")
}
