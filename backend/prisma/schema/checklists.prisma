enum ChecklistAnswerType {
  BOOLEAN
  INTEGER
  DECIMAL
  TEXT
  DATE

  @@map("checklist_answer_type")
}

enum ChecklistStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INVALIDATED

  @@map("checklist_status")
}

enum ChecklistResult {
  PASSED
  FAILED
  WITH_REMARKS

  @@map("checklist_result")
}

model ChecklistModule {
  id              Int                       @id @default(autoincrement())
  name            String                    @unique(map: "uq_checklist_modules_name") @db.VarChar(128)
  description     String?
  isActive        Boolean                   @default(true) @map("is_active")
  sortOrder       Int                       @map("sort_order")
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy       String                    @map("created_by")
  createdByUser   User                      @relation("ChecklistModuleCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updatedAt       DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy       String?                   @map("updated_by")
  updatedByUser   User?                     @relation("ChecklistModuleUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  questions       ChecklistQuestion[]
  templateModules ChecklistTemplateModule[]

  @@index([isActive], map: "idx_checklist_modules_is_active")
  @@index([sortOrder], map: "idx_checklist_modules_sort_order")
  @@map("checklist_modules")
}

model ChecklistQuestion {
  id                Int                         @id @default(autoincrement())
  checklistModuleId Int?                        @map("checklist_module_id")
  questionText      String                      @map("question_text")
  answerType        ChecklistAnswerType         @map("answer_type")
  isActive          Boolean                     @default(true) @map("is_active")
  sortOrder         Int?                        @map("sort_order")
  createdAt         DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy         String                      @map("created_by")
  createdByUser     User                        @relation("ChecklistQuestionCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updatedAt         DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy         String?                     @map("updated_by")
  updatedByUser     User?                       @relation("ChecklistQuestionUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  module            ChecklistModule?            @relation(fields: [checklistModuleId], references: [id], onDelete: Restrict)
  templateQuestions ChecklistTemplateQuestion[]
  checklistDetails  ChecklistDetail[]

  @@index([checklistModuleId], map: "idx_checklist_questions_module_id")
  @@index([checklistModuleId, sortOrder], map: "idx_checklist_questions_module_sort_order")
  @@index([answerType], map: "idx_checklist_questions_answer_type")
  @@index([isActive], map: "idx_checklist_questions_is_active")
  @@map("checklist_questions")
}

model ChecklistTemplate {
  id                      Int                                            @id @default(autoincrement())
  name                    String                                         @db.VarChar(160)
  description             String?
  isPublished             Boolean                                        @default(false) @map("is_published")
  isActive                Boolean                                        @default(false) @map("is_active")
  basedOnTemplateId       Int?                                           @map("based_on_template_id")
  createdAt               DateTime                                       @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy               String                                         @map("created_by")
  createdByUser           User                                           @relation("ChecklistTemplateCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updatedAt               DateTime                                       @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy               String?                                        @map("updated_by")
  updatedByUser           User?                                          @relation("ChecklistTemplateUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)
  publishedAt             DateTime?                                      @map("published_at") @db.Timestamptz(6)
  publishedBy             String?                                        @map("published_by")
  publishedByUser         User?                                          @relation("ChecklistTemplatePublishedBy", fields: [publishedBy], references: [id], onDelete: Restrict)
  archivedAt              DateTime?                                      @map("archived_at") @db.Timestamptz(6)
  archivedBy              String?                                        @map("archived_by")
  archivedByUser          User?                                          @relation("ChecklistTemplateArchivedBy", fields: [archivedBy], references: [id], onDelete: Restrict)
  version                 Int                                            @default(1)
  basedOnTemplate         ChecklistTemplate?                             @relation("ChecklistTemplateCopy", fields: [basedOnTemplateId], references: [id], onDelete: SetNull)
  copiedTemplates         ChecklistTemplate[]                            @relation("ChecklistTemplateCopy")
  modules                 ChecklistTemplateModule[]
  defaultForMaintenanceSettings EquipmentMaintenanceSetting[]            @relation("ChecklistTemplateDefaultForMaintenanceSettings")
  checklists              Checklist[]

  @@index([isActive], map: "idx_checklist_templates_is_active")
  @@index([isPublished], map: "idx_checklist_templates_is_published")
  @@index([basedOnTemplateId], map: "idx_checklist_templates_based_on_id")
  @@map("checklist_templates")
}

model ChecklistTemplateModule {
  id                  Int                         @id @default(autoincrement())
  checklistTemplateId Int                         @map("checklist_template_id")
  checklistModuleId   Int                         @map("checklist_module_id")
  moduleNameSnapshot  String                      @map("module_name_snapshot") @db.VarChar(128)
  sortOrder           Int                         @map("sort_order")
  template            ChecklistTemplate           @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)
  module              ChecklistModule             @relation(fields: [checklistModuleId], references: [id], onDelete: Restrict)
  questions           ChecklistTemplateQuestion[]

  @@unique([checklistTemplateId, checklistModuleId], map: "uq_checklist_template_modules_module")
  @@unique([checklistTemplateId, sortOrder], map: "uq_checklist_template_modules_sort")
  @@map("checklist_template_modules")
}

model ChecklistTemplateQuestion {
  id                        Int                     @id @default(autoincrement())
  checklistTemplateModuleId Int                     @map("checklist_template_module_id")
  checklistQuestionId       Int                     @map("checklist_question_id")
  questionTextSnapshot      String                  @map("question_text_snapshot")
  answerTypeSnapshot        ChecklistAnswerType     @map("answer_type_snapshot")
  sortOrder                 Int                     @map("sort_order")
  isRequired                Boolean                 @default(true) @map("is_required")
  templateModule            ChecklistTemplateModule @relation(fields: [checklistTemplateModuleId], references: [id], onDelete: Cascade)
  question                  ChecklistQuestion       @relation(fields: [checklistQuestionId], references: [id], onDelete: Restrict)
  checklistDetails          ChecklistDetail[]

  @@unique([checklistTemplateModuleId, checklistQuestionId], map: "uq_checklist_template_questions_question")
  @@unique([checklistTemplateModuleId, sortOrder], map: "uq_checklist_template_questions_sort")
  @@map("checklist_template_questions")
}

model Checklist {
  id                   Int             @id @default(autoincrement())
  equipmentEventId     Int             @map("equipment_event_id")
  equipmentId          Int             @map("equipment_id")
  checklistTemplateId  Int             @map("checklist_template_id")
  assignedUserId       String          @map("assigned_user_id")
  sortOrder            Int             @map("sort_order")
  status               ChecklistStatus @default(CREATED)
  result               ChecklistResult?
  checklistDate        DateTime?       @map("checklist_date") @db.Date
  startedAt            DateTime?       @map("started_at") @db.Timestamptz(6)
  startedBy            String?         @map("started_by")
  completedAt          DateTime?       @map("completed_at") @db.Timestamptz(6)
  completedBy          String?         @map("completed_by")
  comment              String?
  cancelledAt          DateTime?       @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy          String?         @map("cancelled_by")
  cancellationReason   String?         @map("cancellation_reason")
  invalidatedAt        DateTime?       @map("invalidated_at") @db.Timestamptz(6)
  invalidatedBy        String?         @map("invalidated_by")
  invalidationReason   String?         @map("invalidation_reason")
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy            String          @map("created_by")
  version              Int             @default(1)
  equipmentEvent       EquipmentEvent   @relation(fields: [equipmentEventId], references: [id], onDelete: Restrict)
  equipment            Equipment        @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  checklistTemplate    ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Restrict)
  assignedUser         User             @relation("ChecklistAssignedUser", fields: [assignedUserId], references: [id], onDelete: Restrict)
  createdByUser        User             @relation("ChecklistCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  startedByUser        User?            @relation("ChecklistStartedBy", fields: [startedBy], references: [id], onDelete: SetNull)
  completedByUser      User?            @relation("ChecklistCompletedBy", fields: [completedBy], references: [id], onDelete: SetNull)
  cancelledByUser      User?            @relation("ChecklistCancelledBy", fields: [cancelledBy], references: [id], onDelete: Restrict)
  invalidatedByUser    User?            @relation("ChecklistInvalidatedBy", fields: [invalidatedBy], references: [id], onDelete: Restrict)
  details              ChecklistDetail[]

  @@unique([equipmentEventId, assignedUserId], map: "uq_checklists_event_assigned_user")
  @@unique([equipmentEventId, sortOrder], map: "uq_checklists_event_sort")
  @@index([equipmentEventId], map: "idx_checklists_event_id")
  @@index([equipmentId], map: "idx_checklists_equipment_id")
  @@index([checklistTemplateId], map: "idx_checklists_template_id")
  @@index([assignedUserId], map: "idx_checklists_assigned_user_id")
  @@index([status], map: "idx_checklists_status")
  @@map("checklists")
}

model ChecklistDetail {
  id                          Int                 @id @default(autoincrement())
  checklistId                 Int                 @map("checklist_id")
  checklistTemplateQuestionId Int?                @map("checklist_template_question_id")
  checklistQuestionId         Int?                @map("checklist_question_id")
  moduleName                  String              @map("module_name")
  moduleSortOrder             Int                 @map("module_sort_order")
  questionText                String              @map("question_text")
  answerType                  ChecklistAnswerType @map("answer_type")
  questionSortOrder           Int                 @map("question_sort_order")
  isRequired                  Boolean             @map("is_required")
  answerBoolean               Boolean?            @map("answer_boolean")
  answerInteger               Int?                @map("answer_integer")
  answerDecimal               Decimal?            @map("answer_decimal") @db.Decimal(18, 6)
  answerText                  String?             @map("answer_text")
  answerDate                  DateTime?           @map("answer_date") @db.Date
  answeredAt                  DateTime?           @map("answered_at") @db.Timestamptz(6)
  answeredBy                  String?             @map("answered_by")
  checklist                   Checklist           @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  templateQuestion            ChecklistTemplateQuestion? @relation(fields: [checklistTemplateQuestionId], references: [id], onDelete: SetNull)
  question                    ChecklistQuestion?  @relation(fields: [checklistQuestionId], references: [id], onDelete: SetNull)
  answeredByUser              User?               @relation("ChecklistDetailAnsweredBy", fields: [answeredBy], references: [id], onDelete: SetNull)

  @@unique([checklistId, moduleSortOrder, questionSortOrder], map: "uq_checklist_details_order")
  @@index([checklistId], map: "idx_checklist_details_checklist_id")
  @@index([checklistTemplateQuestionId], map: "idx_checklist_details_template_question_id")
  @@index([checklistQuestionId], map: "idx_checklist_details_question_id")
  @@index([answeredBy], map: "idx_checklist_details_answered_by")
  @@map("checklist_details")
}
